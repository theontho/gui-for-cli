{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "rootDir": ".",
    "outDir": "dist",
    "strict": false,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "shared/**/*.ts",
    "tui/**/*.ts",
    "web/src/**/*.ts",
    "exp/nodegui/**/*.ts"
  ]
}
