{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Allow the WebUI served by the bundled local backend to use Tauri IPC and updater commands.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://127.0.0.1:*"
    ]
  },
  "permissions": [
    "core:default",
    "updater:default",
    "allow-gfc-update-check",
    "allow-gfc-update-download",
    "allow-gfc-update-install"
  ]
}
