{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Allow the WebUI served by the bundled local backend to use Tauri IPC and updater commands.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://127.0.0.1:*",
      "http://127.0.0.1:*/*",
      "http://localhost:*",
      "http://localhost:*/*"
    ]
  },
  "permissions": ["core:default", "updater:default"]
}
