{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["node", "react", "react-native", "jest"],
    "strict": false,
    "noImplicitAny": false
  },
  "include": [
    "App.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "../../../WebUI/src/shared/**/*.ts"
  ],
  "exclude": ["**/node_modules", "**/Pods"]
}
