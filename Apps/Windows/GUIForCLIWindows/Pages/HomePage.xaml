<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GUIForCLIWindows.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel
                x:Name="PageContent"
                AutomationProperties.Name="Bundle page content"
                Spacing="16" />
        </ScrollViewer>

        <Border
            x:Name="OutputResizeHandle"
            Grid.Row="1"
            Background="Transparent"
            PointerMoved="OutputResizeHandle_PointerMoved"
            PointerPressed="OutputResizeHandle_PointerPressed"
            PointerReleased="OutputResizeHandle_PointerReleased"
            ToolTipService.ToolTip="Drag to resize command output" />

        <Grid Grid.Row="2" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock
                    AutomationProperties.HeadingLevel="Level2"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Command output" />
                <Button
                    x:Name="CopyOutputButton"
                    Click="CopyOutput_Click"
                    Content="Copy"
                    AutomationProperties.Name="Copy command output" />
                <TextBlock
                    x:Name="CopyOutputStatus"
                    VerticalAlignment="Center"
                    Opacity="0.72" />
            </StackPanel>
            <TextBox
                x:Name="OutputBox"
                Grid.Row="1"
                AcceptsReturn="True"
                AutomationProperties.Name="Command output"
                FontFamily="Cascadia Mono, Consolas"
                IsReadOnly="True"
                TextWrapping="NoWrap" />
        </Grid>
    </Grid>
</Page>
