{
  "id": "fastq",
  "title": "pages.fastq.title",
  "summary": "pages.fastq.summary",
  "sidebarGroup": "sidebar.groups.convert",
  "sections": [
    {
      "id": "fastq-align",
      "title": "sections.fastq.fastq-align.title",
      "iconName": "waveform.path.ecg",
      "controls": [
        {
          "id": "fastq_r1",
          "label": "controls.fastq.fastq-inputs.fastq_r1.label",
          "kind": "path",
          "tooltip": "controls.fastq.fastq-inputs.fastq_r1.tooltip"
        },
        {
          "id": "fastq_r2",
          "label": "controls.fastq.fastq-inputs.fastq_r2.label",
          "kind": "path",
          "tooltip": "controls.fastq.fastq-inputs.fastq_r2.tooltip"
        },
        {
          "id": "ref_fasta",
          "label": "controls.fastq.fastq-inputs.ref_fasta.label",
          "kind": "dropdown",
          "tooltip": "controls.fastq.fastq-inputs.ref_fasta.tooltip",
          "dataSource": {
            "path": "scripts/list-reference-genomes.py",
            "arguments": [
              "options",
              "{{ref_path}}"
            ]
          }
        },
        {
          "id": "out_dir",
          "label": "controls.fastq.fastq-inputs.out_dir.label",
          "kind": "path",
          "tooltip": "controls.fastq.fastq-inputs.out_dir.tooltip"
        },
        {
          "id": "fastq_output_format",
          "label": "controls.fastq.fastq-inputs.fastq_output_format.label",
          "kind": "dropdown",
          "value": "BAM",
          "tooltip": "controls.fastq.fastq-inputs.fastq_output_format.tooltip",
          "options": [
            {
              "id": "BAM",
              "title": "options.fastq.fastq-inputs.fastq_output_format.BAM.title",
              "selected": true
            },
            {
              "id": "CRAM",
              "title": "options.fastq.fastq-inputs.fastq_output_format.CRAM.title"
            }
          ]
        }
      ],
      "actions": [
        {
          "id": "align",
          "title": "actions.fastq.fastq-inputs.align.title",
          "tooltip": "actions.fastq.fastq-inputs.align.tooltip",
          "command": {
            "executable": "{{bundleRoot}}/scripts/run-wgsextract.sh",
            "arguments": [
              "align",
              "--r1",
              "{{fastq_r1}}",
              "--ref",
              "{{ref_fasta}}",
              "--format",
              "{{fastq_output_format}}"
            ],
            "optionalArguments": [
              [
                "--outdir",
                "{{out_dir}}"
              ],
              [
                "--r2",
                "{{fastq_r2}}"
              ]
            ]
          }
        },
        {
          "id": "fastqc",
          "title": "actions.fastq.fastq-inputs.fastqc.title",
          "tooltip": "actions.fastq.fastq-inputs.fastqc.tooltip",
          "command": {
            "executable": "{{bundleRoot}}/scripts/run-wgsextract.sh",
            "arguments": [
              "qc",
              "fastqc",
              "--input",
              "{{fastq_r1}}"
            ]
          }
        },
        {
          "id": "fastp",
          "title": "actions.fastq.fastq-inputs.fastp.title",
          "tooltip": "actions.fastq.fastq-inputs.fastp.tooltip",
          "command": {
            "executable": "{{bundleRoot}}/scripts/run-wgsextract.sh",
            "arguments": [
              "qc",
              "fastp",
              "--r1",
              "{{fastq_r1}}"
            ],
            "optionalArguments": [
              [
                "--r2",
                "{{fastq_r2}}"
              ]
            ]
          }
        }
      ]
    },
    {
      "id": "pet-inputs",
      "title": "sections.pet-analysis.pet-inputs.title",
      "iconName": "pawprint",
      "controls": [
        {
          "id": "pet_species",
          "label": "controls.pet-analysis.pet-inputs.pet_species.label",
          "kind": "dropdown",
          "tooltip": "controls.pet-analysis.pet-inputs.pet_species.tooltip",
          "value": "dog",
          "options": [
            {
              "id": "dog",
              "title": "options.pet-analysis.pet-inputs.pet_species.dog.title"
            },
            {
              "id": "cat",
              "title": "options.pet-analysis.pet-inputs.pet_species.cat.title"
            }
          ]
        },
        {
          "id": "pet_fastq_r1",
          "label": "controls.pet-analysis.pet-inputs.pet_fastq_r1.label",
          "kind": "path",
          "tooltip": "controls.pet-analysis.pet-inputs.pet_fastq_r1.tooltip"
        },
        {
          "id": "pet_fastq_r2",
          "label": "controls.pet-analysis.pet-inputs.pet_fastq_r2.label",
          "kind": "path",
          "tooltip": "controls.pet-analysis.pet-inputs.pet_fastq_r2.tooltip"
        },
        {
          "id": "pet_output_format",
          "label": "controls.pet-analysis.pet-inputs.pet_output_format.label",
          "kind": "dropdown",
          "tooltip": "controls.pet-analysis.pet-inputs.pet_output_format.tooltip",
          "value": "BAM",
          "options": [
            {
              "id": "BAM",
              "title": "options.pet-analysis.pet-inputs.pet_output_format.BAM.title"
            },
            {
              "id": "CRAM",
              "title": "options.pet-analysis.pet-inputs.pet_output_format.CRAM.title"
            }
          ]
        }
      ],
      "actions": [
        {
          "id": "pet-align",
          "title": "actions.pet-analysis.pet-inputs.pet-align.title",
          "tooltip": "actions.pet-analysis.pet-inputs.pet-align.tooltip",
          "command": {
            "executable": "{{bundleRoot}}/scripts/run-wgsextract.sh",
            "arguments": [
              "pet-align",
              "--species",
              "{{pet_species}}",
              "--r1",
              "{{pet_fastq_r1}}",
              "--ref",
              "{{ref_path}}",
              "--format",
              "{{pet_output_format}}"
            ],
            "optionalArguments": [
              [
                "--outdir",
                "{{out_dir}}"
              ],
              [
                "--r2",
                "{{pet_fastq_r2}}"
              ]
            ]
          }
        }
      ]
    }
  ],
  "iconName": "text.page"
}
