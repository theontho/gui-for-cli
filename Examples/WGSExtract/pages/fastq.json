{
  "id": "fastq",
  "title": "pages.fastq.title",
  "summary": "pages.fastq.summary",
  "sections": [
    {
      "id": "fastq-inputs",
      "title": "sections.fastq.fastq-inputs.title",
      "iconName": "waveform.path.ecg",
      "controls": [
        {
          "id": "bam_path",
          "label": "controls.fastq.fastq-inputs.bam_path.label",
          "kind": "path",
          "tooltip": "controls.fastq.fastq-inputs.bam_path.tooltip"
        },
        {
          "id": "fastq_r1",
          "label": "controls.fastq.fastq-inputs.fastq_r1.label",
          "kind": "path",
          "tooltip": "controls.fastq.fastq-inputs.fastq_r1.tooltip"
        },
        {
          "id": "fastq_r2",
          "label": "controls.fastq.fastq-inputs.fastq_r2.label",
          "kind": "path",
          "tooltip": "controls.fastq.fastq-inputs.fastq_r2.tooltip"
        },
        {
          "id": "ref_path",
          "label": "controls.fastq.fastq-inputs.ref_path.label",
          "kind": "path",
          "tooltip": "controls.fastq.fastq-inputs.ref_path.tooltip"
        },
        {
          "id": "out_dir",
          "label": "controls.fastq.fastq-inputs.out_dir.label",
          "kind": "path",
          "tooltip": "controls.fastq.fastq-inputs.out_dir.tooltip"
        },
        {
          "id": "fastq_output_format",
          "label": "controls.fastq.fastq-inputs.fastq_output_format.label",
          "kind": "dropdown",
          "value": "BAM",
          "tooltip": "controls.fastq.fastq-inputs.fastq_output_format.tooltip",
          "options": [
            {
              "id": "BAM",
              "title": "options.fastq.fastq-inputs.fastq_output_format.BAM.title",
              "selected": true
            },
            {
              "id": "CRAM",
              "title": "options.fastq.fastq-inputs.fastq_output_format.CRAM.title"
            }
          ]
        },
        {
          "id": "unalign_r1_output",
          "label": "controls.fastq.fastq-inputs.unalign_r1_output.label",
          "kind": "path",
          "tooltip": "controls.fastq.fastq-inputs.unalign_r1_output.tooltip"
        },
        {
          "id": "unalign_r2_output",
          "label": "controls.fastq.fastq-inputs.unalign_r2_output.label",
          "kind": "path",
          "tooltip": "controls.fastq.fastq-inputs.unalign_r2_output.tooltip"
        }
      ],
      "actions": [
        {
          "id": "align",
          "title": "actions.fastq.fastq-inputs.align.title",
          "tooltip": "actions.fastq.fastq-inputs.align.tooltip",
          "command": {
            "executable": "{{bundleRoot}}/scripts/run-wgsextract.sh",
            "arguments": [
              "align",
              "--r1",
              "{{fastq_r1}}",
              "--ref",
              "{{ref_path}}",
              "--format",
              "{{fastq_output_format}}"
            ],
            "optionalArguments": [
              [
                "--outdir",
                "{{out_dir}}"
              ],
              [
                "--r2",
                "{{fastq_r2}}"
              ]
            ]
          }
        },
        {
          "id": "unalign",
          "title": "actions.fastq.fastq-inputs.unalign.title",
          "tooltip": "actions.fastq.fastq-inputs.unalign.tooltip",
          "command": {
            "executable": "{{bundleRoot}}/scripts/run-wgsextract.sh",
            "arguments": [
              "bam",
              "unalign",
              "--input",
              "{{bam_path}}",
              "--outdir",
              "{{out_dir}}",
              "--r1",
              "{{unalign_r1_output}}",
              "--r2",
              "{{unalign_r2_output}}"
            ]
          }
        },
        {
          "id": "fastq-index",
          "title": "actions.fastq.fastq-inputs.fastq-index.title",
          "tooltip": "actions.fastq.fastq-inputs.fastq-index.tooltip",
          "command": {
            "executable": "{{bundleRoot}}/scripts/run-wgsextract.sh",
            "arguments": [
              "bam",
              "index",
              "--input",
              "{{bam_path}}"
            ]
          }
        },
        {
          "id": "fastqc",
          "title": "actions.fastq.fastq-inputs.fastqc.title",
          "tooltip": "actions.fastq.fastq-inputs.fastqc.tooltip",
          "command": {
            "executable": "{{bundleRoot}}/scripts/run-wgsextract.sh",
            "arguments": [
              "qc",
              "fastqc",
              "--input",
              "{{fastq_r1}}"
            ]
          }
        },
        {
          "id": "fastp",
          "title": "actions.fastq.fastq-inputs.fastp.title",
          "tooltip": "actions.fastq.fastq-inputs.fastp.tooltip",
          "command": {
            "executable": "{{bundleRoot}}/scripts/run-wgsextract.sh",
            "arguments": [
              "qc",
              "fastp",
              "--r1",
              "{{fastq_r1}}"
            ],
            "optionalArguments": [
              [
                "--r2",
                "{{fastq_r2}}"
              ]
            ]
          }
        },
        {
          "id": "fastq-vcf-qc",
          "title": "actions.fastq.fastq-inputs.fastq-vcf-qc.title",
          "tooltip": "actions.fastq.fastq-inputs.fastq-vcf-qc.tooltip",
          "command": {
            "executable": "{{bundleRoot}}/scripts/run-wgsextract.sh",
            "arguments": [
              "qc",
              "vcf",
              "--input",
              "{{bam_path}}"
            ]
          }
        }
      ]
    }
  ],
  "iconName": "text.page"
}
