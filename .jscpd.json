{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/packages/jscpd/schema.json",
  "threshold": 0.5,
  "minLines": 30,
  "minTokens": 70,
  "reporters": ["console", "html"],
  "output": "./out/jscpd",
  "gitignore": true,
  "absolute": false,
  "pattern": "**/*.{ts,js,mjs,py,rs,swift,kt,dart,cpp,c,h,hpp}",
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/dist-electron/**",
    "**/out/**",
    "**/target/**",
    "**/build/**",
    "**/.build/**",
    "**/.venv/**",
    "**/.gradle/**",
    "**/.dart_tool/**",
    "**/exp-platform/**",
    "**/__pycache__/**",
    "**/DerivedData/**",
    "**/coverage/**",
    "**/*.lock",
    "**/package-lock.json",
    "**/Cargo.lock",
    "**/site/**",
    "**/docs/ai/screenshots/**",
    "**/examples/**/genomes/**",
    "**/examples/**/runtime/**",
    "**/examples/**/output/**",
    "**/examples/**/reference/**",
    "**/examples/**/settings/**",
    "**/.git/**",
    "**/.copilot/**",
    "**/Derived/**",
    "**/Generated/**"
  ]
}
