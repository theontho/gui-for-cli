      "vcf_father": "{{bundleWorkspace}}/genomes/wgsextract-benchmark-hg19-mini/HG00096.hg19-mini.vcf.gz"
    },
    "checkedOptions": {
      "microarray_formats": [
        "23andme_v5",
        "ancestry_v2",
        "ftdna_v3",
        "myheritage_v2"
      ]
