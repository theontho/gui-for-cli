    {
      "id": "download-hg19",
      "kind": "action",
      "pageID": "library",
      "sectionID": "genome-management",
      "controlID": "reference_genomes",
      "actionID": "ref-download",
      "rowID": "hg19-UCSC-hg19.fa.gz",
      "rowValues": {
        "build": "GRCh37 / hg19",
        "code": "hg19",
        "final": "hg19.fa.gz",
        "name": "hg19",
        "ref": "{{bundleWorkspace}}/reference/genomes/hg19.fa.gz",
        "source": "UCSC",
        "status": "missing"
      },
      "timeoutSeconds": 14400
    },
    {
