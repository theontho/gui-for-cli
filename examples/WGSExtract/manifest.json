{
  "id": "wgs-extract",
  // Keep this bundle version in sync with scripts/wgsextract-release-tag.txt so installer names match the bundled WGSExtract CLI release.
  "version": "0.3.7",
  "displayName": "bundle.displayName",
  "summary": "bundle.summary",
  "iconName": "fasta",
  "textIcon": "🧬",
  "iconPath": "Assets/icon.png",
  "sidebarIconStyle": "automatic",
  "terminalTextDirection": "ltr",
  "setup": {
    "initialInstallSizeGB": 6,
    "steps": [
      {
        "id": "xcode-command-line-tools",
        "kind": "setupScript",
        "label": "setup.xcode-command-line-tools.label",
        "value": "scripts/check-xcode-command-line-tools.sh",
        "platforms": [
          "macos"
        ]
      },
      {
        "id": "pixi",
        "kind": "setupScript",
        "label": "setup.pixi.label",
        "value": "scripts/check-preinstalled-pixi.sh",
        "environment": {
          "WGSEXTRACT_MSYS2_ROOT": "{{applicationSupport}}/msys64"
        }
      },
      {
        "id": "install-wgsextract",
        "kind": "setupScript",
        "label": "setup.install-wgsextract.label",
        "value": "scripts/setup-wgsextract-pixi.sh",
        "arguments": [],
        "platforms": [
          "posix"
        ],
        "toolName": "WGS Extract CLI",
        "toolVersionFile": "scripts/wgsextract-release-tag.txt",
        "environment": {
          "WGSEXTRACT_INSTALL_DIR": "{{bundleRoot}}/runtime/wgsextract-cli"
        }
      },
      {
        "id": "install-wgsextract-windows",
        "kind": "setupScript",
        "label": "setup.install-wgsextract.label",
        "value": "scripts/setup-wgsextract-pixi.sh",
        "arguments": [],
        "requiresAdmin": true,
        "platforms": [
          "windows"
        ],
        "toolName": "WGS Extract CLI",
        "toolVersionFile": "scripts/wgsextract-release-tag.txt",
        "environment": {
          "WGSEXTRACT_INSTALL_DIR": "{{bundleRoot}}/runtime/wgsextract-cli",
          "WGSEXTRACT_MSYS2_ROOT": "{{applicationSupport}}/msys64"
        }
      },
      {
        "id": "wgsextract-cli",
        "kind": "pathTool",
        "label": "setup.wgsextract.label",
        "value": "{{bundleRoot}}/runtime/wgsextract-cli/bin/wgsextract",
        "optional": true,
        "platforms": [
          "posix"
        ]
      },
      {
        "id": "wgsextract-cli-windows",
        "kind": "pathTool",
        "label": "setup.wgsextract.label",
        "value": "{{bundleRoot}}/runtime/wgsextract-cli/bin/wgsextract.cmd",
        "optional": true,
        "platforms": [
          "windows"
        ]
      },
      {
        "id": "bootstrap-reference-library",
        "kind": "setupScript",
        "label": "Download bootstrap reference library",
        "value": "scripts/bootstrap-reference-library.sh",
        "arguments": []
      }
    ]
  },
  "uninstall": {
    "steps": [
      {
        "id": "cleanup-wgsextract-runtime",
        "kind": "setupScript",
        "label": "Cleanup WGS Extract runtime",
        "value": "scripts/uninstall-wgsextract.sh"
      }
    ]
  },
  "pages": [
    "fastq.json",
    "info-bam.json",
    "vcf.json",
    "extract.json",
    "microarray.json",
    "ancestry.json",
    "annotate.json",
    "library.json",
    "settings.json"
  ]
}
