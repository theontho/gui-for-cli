{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GUI for CLI WebUI",
  "version": "0.1.0",
  "identifier": "dev.guiforcli.webui",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/icon.png",
      "../../Apps/Windows/GUIForCLIWindows/Assets/AppIcon.ico"
    ],
    "resources": {
      "../dist": "WebUI/dist",
      "../index.html": "WebUI/index.html",
      "../styles.css": "WebUI/styles.css",
      "../vendor": "WebUI/vendor",
      "resources/node": "node",
      "../../Examples/WGSExtract": "Examples/WGSExtract",
      "../../Sources/GUIForCLICore/Resources/BuiltinStrings": "Sources/GUIForCLICore/Resources/BuiltinStrings"
    },
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
