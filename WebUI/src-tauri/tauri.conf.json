{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GUI for CLI WebUI",
  "version": "0.1.0",
  "identifier": "dev.guiforcli.webui",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": {
      "../dist": "WebUI/dist",
      "../index.html": "WebUI/index.html",
      "../styles.css": "WebUI/styles.css",
      "../vendor": "WebUI/vendor",
      "resources/node": "node",
      "../../Examples/WGSExtract": "Examples/WGSExtract"
    },
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
