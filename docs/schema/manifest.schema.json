{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theontho/gui-for-cli/schema/manifest.schema.json",
  "title": "GUI for CLI Bundle Manifest",
  "type": "object",
  "required": ["id", "displayName", "summary", "pages"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "iconName": { "type": "string" },
    "iconPath": { "type": "string" },
    "iconEmoji": { "type": "string" },
    "sidebarIconStyle": {
      "type": "string",
      "enum": ["automatic", "image", "emoji", "symbol", "hidden"]
    },
    "setup": { "$ref": "#/$defs/setup" },
    "exitCodeReference": {
      "description": "Optional descriptions for process exit codes. Entries override app-provided defaults for the same code, and title/summary can be strings.toml localization keys.",
      "type": "array",
      "items": { "$ref": "#/$defs/exitCodeReferenceEntry" },
      "default": []
    },
    "pages": {
      "description": "Ordered page file names in the bundle pages/ directory, or legacy inline page objects.",
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[^/]+\\.json$"
          },
          "uniqueItems": true,
          "minItems": 1
        },
        {
          "type": "array",
          "items": { "$ref": "page.schema.json" },
          "minItems": 1
        }
      ]
    }
  },
  "$defs": {
    "setup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/setupStep" },
          "default": []
        }
      }
    },
    "exitCodeReferenceEntry": {
      "type": "object",
      "required": ["code", "title", "summary"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "integer" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["warning", "error"],
          "default": "error"
        }
      }
    },
    "setupStep": {
      "type": "object",
      "required": ["id", "kind", "label", "value"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["bundledScript", "setupScript", "pathTool", "homebrewPackage", "pixiInstall", "pixiRun"]
        },
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 },
        "arguments": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "environment": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {}
        },
        "workingDirectory": { "type": "string" },
        "optional": { "type": "boolean", "default": false }
      }
    }
  }
}
